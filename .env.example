# Copy this file to `.env` (gitignored) and fill in your values.

# OAuth client ID for the optional Google Photos destination.
# Create a "Web application" OAuth client in Google Cloud, enable the Photos
# Library API and Photos Picker API, and register the extension's redirect URI
# (https://<EXTENSION_ID>.chromiumapp.org/). Leave empty to disable the Google
# Photos destination entirely.
IMAGEVAULT_GOOGLE_CLIENT_ID=
